@using LerningApp.Web.ViewModels.VocabularyCard
@model VocabularyCardsIndexViewModel
<style>
    .flashcard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 16px;
    }
    .word-card {
        display: block;
        text-decoration: none;
        color: #111827;
        background: #ffffff;
        border: 1px solid #f1e4d7;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .word-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 28px rgba(15, 23, 42, 0.12);
        border-color: rgba(255, 146, 66, 0.55);
    }

    .card-top {
        display: flex;
        gap: 8px;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .pos-badge {
        background: rgba(255, 233, 217, 1);
        color: rgba(168, 82, 30, 1);
        font-weight: 600;
        font-size: 0.75rem;
        padding: 4px 10px;
        border-radius: 999px;
    }

    .gender-badge {
        background: rgba(255, 248, 221, 1);
        color: rgba(145, 91, 20, 1);
        font-weight: 600;
        font-size: 0.75rem;
        padding: 4px 10px;
        border-radius: 999px;
    }

    .card-word {
        font-size: 1.25rem;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .card-sub {
        color: #6b7280;
        font-size: 0.95rem;
    }


</style>

<h2 class="mb-3">Думи за урок: @Model.LessonName</h2>

<div class="flashcard-grid">
    @foreach (var c in Model.Cards)
    {
        <a asp-action="Details"
           asp-route-id="@c.Id"
           class="word-card">
            <div class="card-top">
                <span class="pos-badge">@c.PartOfSpeech</span>
                @if (!string.IsNullOrWhiteSpace(c.Gender))
                {
                    <span class="gender-badge">@c.Gender</span>
                }
            </div>

            <div class="card-word">@c.German</div>
            <div class="card-sub">@c.English</div>
        </a>

    }
</div>

