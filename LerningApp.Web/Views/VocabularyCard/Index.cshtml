@using LerningApp.Web.ViewModels.VocabularyCard
@model VocabularyCardsIndexViewModel

<style>
    :root {
        --ink: #0f172a;
        --muted: #64748b;
        --line: #e2e8f0;
        --card: #ffffff;
        --accent: #ea580c;
        --accent-soft: #fff7ed;
        --success: #16a34a;
        --success-soft: #e7f9ef;
        --shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
        --shadow-hover: 0 16px 28px rgba(15, 23, 42, 0.12);
    }
    


    .flashcard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 16px;
    }

    .word-card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 16px;
        box-shadow: var(--shadow);
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .word-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-hover);
        border-color: #fdba74;
    }

    .word-card.marked {
        border-color: #86efac;
        background: linear-gradient(180deg, #ffffff 0%, #f0fdf4 100%);
    }

    .word-card.marked::after {
        content: "✓ Научена";
        position: absolute;
        top: 10px;
        right: 10px;
        font-size: 0.7rem;
        font-weight: 700;
        color: #166534;
        background: var(--success-soft);
        border: 1px solid #b7f0cc;
        padding: 3px 8px;
        border-radius: 999px;
    }

    .card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .card-top {
        display: flex;
        gap: 8px;
        justify-content: space-between;
        align-items: center;
    }

    .pos-badge, .gender-badge {
        font-weight: 600;
        font-size: 0.72rem;
        padding: 4px 10px;
        border-radius: 999px;
        border: 1px solid transparent;
    }

    .pos-badge {
        background: #fff1e6;
        color: #9a3412;
        border-color: #fed7aa;
    }

    .gender-badge {
        background: #fef9c3;
        color: #854d0e;
        border-color: #fde68a;
    }

    .card-word {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--ink);
        margin-bottom: 4px;
    }

    .card-sub {
        color: var(--muted);
        font-size: 0.95rem;
    }

    .btn-add-card {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: linear-gradient(180deg, #fb923c, #f97316);
        color: #fff !important;
        border: none;
        box-shadow: 0 8px 18px rgba(255, 122, 48, 0.25);
        font-weight: 600;
        text-decoration: none;
        margin-bottom: 12px;
    }

    .btn-add-card:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 22px rgba(255, 122, 48, 0.30);
    }

    .btn-add-card .plus {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.25);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }
    .mark-btn {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        border: 1px solid #bbf7d0;
        background: #f0fdf4;
        color: #166534;
        font-weight: 800;
        display: grid;
        place-items: center;
        padding: 0;
    }
    .mark-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 16px rgba(22, 163, 74, 0.12);
    }
</style>

<h2 class="mb-3">Думи за урок: @Model.LessonName</h2>
<a asp-action="Create"
   asp-controller="VocabularyCard"
   asp-route-lessonId="@Model.LessonId"
   class="btn btn-add-card">
    <span class="plus">+</span> Добави карта
</a>

<div class="flashcard-grid">
    @foreach (var c in Model.Cards)
    {
        <div class="word-card">
            <a asp-action="Details"
               asp-route-id="@c.Id"
               class="card-link">
                <div class="card-top">
                    <span class="pos-badge">@c.PartOfSpeech</span>
                    @if (!string.IsNullOrWhiteSpace(c.Gender))
                    {
                        <span class="gender-badge">@c.Gender</span>
                    }
                </div>

                <div class="card-word">@c.German</div>
                <div class="card-sub">@c.English</div>
            </a>

            <button type="button" class="mark-btn" aria-label="Маркирай като научена">✓</button>
        </div>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.word-card').forEach(card => {
            const btn = card.querySelector('.mark-btn');
            if (!btn) return;

            btn.addEventListener('click', () => {
                card.classList.add('marked');
                btn.style.display = 'none';
            });
        });
    });
</script>
