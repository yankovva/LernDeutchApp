@using LerningApp.Web.ViewModels.Lesson
@model AddLessonInputModel

@{
    ViewData["Title"] = "Create Lesson";
}

<style>
    .hint { font-size: .9rem; color: #6c757d; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">➕ Нов урок</h1>
        <div class="text-muted">Създай урок и (по избор) го закачи към курс.</div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Име на урока</label>
                        <input asp-for="Name" class="form-control" placeholder="Пример: Present Simple – introduction" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CourseId" class="form-label">Курс (по избор)</label>
                        <select asp-for="CourseId" class="form-select">
                            <option value="">— Без курс —</option>
                            @foreach (var c in Model.Courses)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                        <div class="hint mt-1">Можеш да оставиш урока без курс и да го добавиш по-късно.</div>
                        <span asp-validation-for="CourseId" class="text-danger"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="OrderIndex" class="form-label">Order index</label>
                            <input asp-for="OrderIndex" class="form-control" type="number" min="1" />
                            <span asp-validation-for="OrderIndex" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Target" class="form-label">Цел на урока</label>
                        <textarea asp-for="Target" class="form-control" rows="1"
                                  placeholder="Пример: Да можеш да описваш дома си."></textarea>
                        <span asp-validation-for="Target" class="text-danger"></span>
                    </div>

                    <div class="mb-3 mt-3">
                        <label asp-for="Content" class="form-label">Съдържание</label>
                        <textarea asp-for="Content" class="form-control" rows="3"
                                  placeholder="Напиши съдържанието на урока..."></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>
                    <div class="mb-3 mt-3">
                        <label asp-for="Grammar" class="form-label">Граматика</label>
                        <textarea asp-for="Grammar" class="form-control" rows="8"
                                  placeholder="Напиши граматиката на урока..."></textarea>
                        <span asp-validation-for="Grammar" class="text-danger"></span>
                    </div>
                    <div class="mb-3 mt-3">
                        <label asp-for="Exercise" class="form-label">Упражнения</label>
                        <textarea asp-for="Exercise" class="form-control" rows="8"
                                  placeholder="Напиши упражненията към урока..."></textarea>
                        <span asp-validation-for="Exercise" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">💾 Създай</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
