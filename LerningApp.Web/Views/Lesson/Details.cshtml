@using System.Security.Claims
@using LerningApp.Common
@using LerningApp.Web.ViewModels.Lesson
@model LessonContentViewModel

@{
    ViewData["Title"] = "Lesson Details";
}

<style>
    .meta-pill {
        border: 1px solid #dee2e6;
        border-radius: 999px;
        padding: 6px 12px;
        background: #fff;
        font-size: 0.9rem;
    }

    .lesson-section {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 16px;
        background: #fff;
        margin-bottom: 16px;
    }

    .lesson-section h5 {
        margin-bottom: 10px;
    }

    .lesson-content {
        white-space: pre-wrap;
        line-height: 1.7;
        font-size: 1rem;
    }

    .section-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: #6b7280;
        letter-spacing: 0.04em;
        margin-bottom: 6px;
    }
    .lesson-sections {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-top: 16px;
    }

    .section-card {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 14px;
        background: #ffffff;
    }

    .section-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .section-type {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        color: #334155;
        background: #f1f5f9;
        padding: 4px 8px;
        border-radius: 999px;
    }

    .section-order {
        font-size: 0.75rem;
        color: #94a3b8;
    }

    .section-content {
        white-space: pre-wrap;
        line-height: 1.6;
    }
</style>

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="mb-2">@Model.Name</h1>

        <div class="d-flex flex-wrap gap-2">
            <span class="meta-pill">🧾 Думи в урока: <strong>@Model.WordCount</strong></span>
            <span class="meta-pill">🔢 Номер в курса: <strong>@Model.OrderIndex</strong></span>

            @if (!string.IsNullOrWhiteSpace(Model.CourseName))
            {
                <span class="meta-pill">
                    📚 Курс: <strong>@Model.CourseName</strong>
                </span>
            }
            else
            {
                <span class="meta-pill">📚 Без курс</span>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        @if (User.Identity?.IsAuthenticated == true &&
             Model.PublisherId == User.FindFirstValue(ClaimTypes.NameIdentifier))
        {
            <form asp-action="SoftDelete" method="post"
                  onsubmit="return confirm('Сигурне ли сте, че искате да изтриете този урок?');"
                  class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id"/>
                <button type="submit" class="btn btn-danger btn-sm">Изтрий</button>
            </form>
            <a asp-action="Create" method="get" asp-controller="MultipleChoiceExercise"
                    asp-route-lessonId="@Model.Id" class="btn btn-primary">
                + Добави упражнение
            </a>
           
        }
       
        @if (Model.CourseId != null)
        {
            <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId"
               class="btn btn-outline-primary">
                Виж курс
            </a>
        }

        <a asp-action="Index" class="btn btn-outline-secondary">
            ← Назад
        </a>

        <a asp-controller="VocabularyCard" asp-action="Index" asp-route-lessonId="@Model.Id"
           class="btn btn-outline-primary">
            Flashcards
        </a>
    </div>
</div>

<div class="lesson-section">
    <div class="section-label">Цел на урока</div>
    @if (string.IsNullOrWhiteSpace(Model.Target))
    {
        <p class="text-muted mb-0 fst-italic">Няма зададена цел за този урок.</p>
    }
    else
    {
        <div class="lesson-content">@Model.Target</div>
    }
</div>


<div class="lesson-section">
    <div class="section-label">Съдържание</div>
    @if (string.IsNullOrWhiteSpace(Model.Content))
    {
        <p class="text-muted mb-0 fst-italic">Няма съдържание за този урок.</p>
    }
    else
    {
        <div class="lesson-content">@Model.Content</div>
    }
</div>
@if (Model.LessonSections != null && Model.LessonSections.Any())
{
    <div class="lesson-sections">
        @foreach (var s in Model.LessonSections.OrderBy(s => s.OrderIndex))
        {
            <div class="section-card">
                <div class="section-head">
                    <span class="section-type">@s.Type</span>
                    <span class="section-order">#@s.OrderIndex</span>
                </div>
                <div class="section-content">
                    @s.Content
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted fst-italic">Няма секции за този урок.</p>
}

@if (Model.MultipleChoiceExercises.Any())
{
    <h4 class="mt-4">Упражнения</h4>

    @foreach (var ex in Model.MultipleChoiceExercises)
    {
        // Randoom order of the answers
        var answers = new List<string>
            {
                ex.CorrectAnswer,
                ex.FirstWrongAnswer,
                ex.SecondWrongAnswer,
                ex.ThirdWrongAnswer ?? ""
            }.Where(a => !string.IsNullOrWhiteSpace(a))
            .OrderBy(_ => Guid.NewGuid())
            .ToList();

        <form asp-action="CheckMultipleChoice" method="post" 
              asp-controller="MultipleChoiceExercise" class="exercise-box">
            @Html.AntiForgeryToken()
            <input type="hidden" name="exerciseId" value="@ex.Id" />
            <input type="hidden" name="lessonId" value="@Model.Id" />

            <div class="question">@ex.Question</div>

            @for (int i = 0; i < answers.Count; i++)
            {
                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           name="selectedAnswer"
                           value="@answers[i]"
                           required />
                    <label class="form-check-label">@answers[i]</label>
                </div>
            }
            <button type="submit" class="btn btn-sm btn-primary mt-2">Провери</button>
        </form>
    }
}



