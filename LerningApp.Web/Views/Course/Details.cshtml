@using System.Security.Claims
@using LerningApp.Web.ViewModels.Course
@model CourseDetailsViewModel

@{
    ViewData["Title"] = "Course Details";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <h2 class="mb-1">@Model.Name</h2>
                        <div class="text-muted">
                            Ниво:
                            <span class="badge bg-secondary">
                                @(Model.LevelName ?? "—")
                            </span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="d-flex gap-2">
                            @if (User.Identity?.IsAuthenticated == true &&
                                 Model.PublisherId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                            {
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                    Редактирай
                                </a>
                            }
                            <a asp-action="Index"
                               class="btn btn-outline-secondary">
                                ← Всички курсове
                            </a>
                            @if (Model.IsEnrolled == false)
                            {
                                <form asp-action="Enroll" method="post" class="d-inline">
                                    <input type="hidden" name="courseId" value="@Model.Id"/>
                                    <button type="submit" class="btn btn-primary">Запиши се</button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-success">Записан</span>
                            }
                        </div>

                        @if (Model.IsActive)
                        {
                            <form asp-action="Deactivate"
                                  asp-route-id="@Model.Id"
                                  method="post"
                                  onsubmit="return confirm('Сигурни ли сте, че искате да деактивирате този курс?');">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-outline-danger">
                                    🗄️ Деактивирай
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Restore"
                                  asp-route-id="@Model.Id"
                                  method="post"
                                  onsubmit="return confirm('Сигурни ли сте, че искате да активирате този курс?');">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-outline-success">
                                    ♻️ Възстанови курса
                                </button>
                            </form>
                        }
                    </div>

                </div>

                <hr class="my-4" />

                <h5 class="mb-2">Описание</h5>

                @if (string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="text-muted mb-0">Няма описание за този курс.</p>
                }
                else
                {
                    <p class="mb-0">@Model.Description</p>
                }

                <hr class="my-4" />
                
                <h4 class="mt-4 mb-3">Уроци в курса</h4>

                @if (!Model.CourseLessons.Any())
                {
                    <div class="alert alert-info">Все още няма уроци в този курс.</div>
                }
                else
                {
                    <div class="lesson-grid">
                        @foreach (var lesson in Model.CourseLessons)
                        {
                            <div class="lesson-card">
                                <div class="lesson-title">@lesson.LessonName</div>
                                <div class="lesson-desc">@lesson.LessonTarget</div>
                                <div class="lesson-meta">@lesson.WordsInLesson думи</div>

                                <a asp-controller="Lesson"
                                   asp-action="Details"
                                   asp-route-id="@lesson.LessinId"
                                   class="btn btn-outline-primary btn-sm">
                                    Отвори урок
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
           
        </div>
    </div>
</div>
<style>
    .lesson-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 14px;
    }

    .lesson-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 14px;
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.06);
    }

    .lesson-title {
        font-weight: 700;
        margin-bottom: 4px;
    }

    .lesson-desc {
        color: #475569;
        font-size: 0.95rem;
        min-height: 38px;
        margin-bottom: 8px;
    }

    .lesson-meta {
        font-size: 0.85rem;
        color: #6b7280;
        margin-bottom: 10px;
    }
</style>