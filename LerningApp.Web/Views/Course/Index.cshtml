@using LerningApp.Web.ViewModels.Course
@model IEnumerable<CourseIndexViewModel>

@{
    ViewData["Title"] = "Courses";
}

<div class="courses-page">
    <div class="courses-hero">
        <div class="hero-content">
            <div class="eyebrow">Каталог</div>
            <h1 class="title">Открий следващия си курс</h1>
            <p class="subtitle">
                Избери от подбрани курсове, създадени да те водят стъпка по стъпка.
                Всеки курс има ясна цел, структура и практическа насоченост.
            </p>
            <div class="hero-actions">
                <a href="#course-grid" class="btn btn-accent btn-pill">Разгледай курсовете</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-action="Create" class="btn btn-outline btn-pill">
                        + Нов курс
                    </a>
                }
            </div>
        </div>
        <div class="hero-blob"></div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            Все още няма добавени курсове.
        </div>
    }
    else
    {
        <div id="course-grid" class="course-grid">
            @foreach (var course in Model)
            {
                <div class="course-card @(course.IsActive == false ? "inactive" : "")">
                    <div class="course-top">
                        <span class="badge badge-level">@course.CourseLevel</span>
                        @if (course.IsEnrolled)
                        {
                            <span class="badge badge-enrolled">Записан</span>
                        }
                        
                        @if (course.IsActive == false)
                        {
                            <span class="badge badge-inactive">Неактивен</span>
                        }
                    </div>

                    <div class="course-name">@course.Name</div>
                    <div class="course-meta">
                        <span>📘 @course.LessonsCount уроци</span>
                    </div>
                    <div class="course-meta">
                        <span>🧑‍🎓 @course.EnrolledCount записани</span>
                    </div>
                    <div class="side-price">
                        <span>💻 Онлайн</span>
                        <strong>@course.Price €</strong>
                    </div>

                    <div class="course-actions">
                        <a asp-action="Details"
                           asp-route-id="@course.Id"
                           class="btn btn-accent btn-pill w-100">
                            Виж курса →
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .courses-page {
        background: linear-gradient(135deg, rgba(255, 245, 235, 1), rgba(255, 255, 255, 1));
        border-radius: 22px;
        padding: 16px 0 24px 0;
    }

    .courses-hero {
        position: relative;
        padding: 28px 0 18px 0;
        margin-bottom: 10px;
        overflow: hidden;
    }

    .hero-content {
        max-width: 720px;
    }

    .hero-blob {
        position: absolute;
        right: -120px;
        top: -90px;
        width: 320px;
        height: 320px;
        background: radial-gradient(circle at 30% 30%, rgba(255, 177, 102, 0.6), rgba(255, 255, 255, 0));
        filter: blur(10px);
        pointer-events: none;
    }

    .eyebrow {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: .12em;
        color: rgba(124, 133, 146, 1);
        margin-bottom: 6px;
    }

    .title {
        font-size: 2.4rem;
        font-weight: 800;
        margin: 0 0 10px 0;
        color: rgba(28, 35, 50, 1);
    }

    .subtitle {
        color: rgba(94, 102, 118, 1);
        line-height: 1.6;
        margin-bottom: 18px;
    }

    .hero-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-pill {
        border-radius: 999px;
        padding: 8px 16px;
    }

    .btn-accent {
        background: linear-gradient(180deg, rgba(255, 138, 76, 1), rgba(255, 122, 48, 1));
        color: white;
        border: none;
        box-shadow: 0 10px 20px rgba(255, 122, 48, 0.25);
    }

    .btn-outline {
        background: white;
        border: 1px solid rgba(255, 162, 114, 0.7);
        color: rgba(255, 122, 48, 1);
    }

    .course-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 16px;
    }

    .course-card {
        background: white;
        border: 1px solid rgba(240, 224, 210, 1);
        border-radius: 18px;
        padding: 16px;
        box-shadow: 0 10px 24px rgba(35, 40, 55, 0.08);
        display: flex;
        flex-direction: column;
        gap: 8px;
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .course-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 28px rgba(35, 40, 55, 0.12);
    }

    .course-card.inactive {
        opacity: 0.75;
        filter: grayscale(0.15);
    }

    .course-top {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
    }

    .badge {
        border-radius: 999px;
        padding: 4px 10px;
        font-size: 0.75rem;
        font-weight: 600;
        border: 1px solid transparent;
    }

    .badge-level {
        background: rgba(255, 238, 224, 1);
        color: rgba(160, 83, 32, 1);
        border-color: rgba(255, 210, 180, 1);
    }

    .badge-enrolled {
        background: rgba(225, 248, 238, 1);
        color: rgba(28, 115, 80, 1);
        border-color: rgba(180, 235, 210, 1);
    }

    .badge-inactive {
        background: rgba(243, 244, 246, 1);
        color: rgba(107, 114, 128, 1);
        border-color: rgba(229, 231, 235, 1);
    }

    .course-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: rgba(28, 35, 50, 1);
        margin-top: 6px;
    }

    .course-meta {
        color: rgba(94, 102, 118, 1);
        font-size: 0.9rem;
        margin-bottom: 10px;
    }

    .course-actions {
        margin-top: auto;
    }

    .empty-state {
        padding: 16px;
        color: rgba(94, 102, 118, 1);
        background: white;
        border: 1px solid rgba(240, 224, 210, 1);
        border-radius: 14px;
        box-shadow: 0 8px 18px rgba(35, 40, 55, 0.06);
    }
    .courses-page {
        padding: 24px 28px 32px 28px;
    }
    .courses-hero {
        padding: 32px 16px 20px 16px;
    }

</style>
