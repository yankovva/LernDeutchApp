@model LerningApp.Web.ViewModels.ListeningExercise.CreateListeningExerciseViewModel

@{
    ViewData["Title"] = "Create Listening Exercise";
}

<h2>Create Listening Exercise</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data" id="listeningForm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="LessonId" type="hidden" />

    <div class="mb-3">
        <label asp-for="AudioFile" class="form-label"></label>
        <input asp-for="AudioFile" type="file" class="form-control" accept=".mp3,.wav,.ogg,.m4a,audio/*" />
        <span asp-validation-for="AudioFile" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DifficultyLevel" class="form-label"></label>
        <input asp-for="DifficultyLevel" type="number" min="1" max="5" class="form-control" />
        <span asp-validation-for="DifficultyLevel" class="text-danger"></span>
    </div>

    <hr />

    @for (var i = 0; i < 10; i++)
    {
        <div class="border rounded p-3 mb-3">
            <h5>Question @(i + 1)</h5>

            <div class="mb-2">
                <label class="form-label">Question text</label>
                <input name="Questions[@i].QuestionText" class="form-control" />
                <input type="hidden" name="Questions[@i].OrderIndex" value="@(i + 1)" />
            </div>

            @for (var j = 0; j < 4; j++)
            {
                <div class="row mb-2 align-items-center">
                    <div class="col-md-8">
                        <input name="Questions[@i].Options[@j].AnswerText" class="form-control" placeholder="Option @(j + 1)" />
                        <input type="hidden" name="Questions[@i].Options[@j].OrderIndex" value="@(j + 1)" />
                        <input type="hidden"
                               name="Questions[@i].Options[@j].IsCorrect"
                               value="false"
                               class="is-correct-q-@i" />
                    </div>
                    <div class="col-md-4">
                        <input type="radio"
                               name="correct_@i"
                               onchange="setCorrect(@i, @j)" />
                        <label>Correct</label>
                    </div>
                </div>
            }
        </div>
    }

    <button type="submit" class="btn btn-primary">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function setCorrect(questionIndex, optionIndex) {
            const allHidden = document.querySelectorAll('.is-correct-q-' + questionIndex);
            allHidden.forEach(x => x.value = 'false');

            const target = document.querySelector(
                `input[name="Questions[${questionIndex}].Options[${optionIndex}].IsCorrect"]`
            );
            if (target) target.value = 'true';
        }
    </script>
}
