@using LerningApp.Web.ViewModels.ListeningExercise
@model CreateListeningExerciseViewModel

@{
    ViewData["Title"] = "Create Listening Exercise";
}

<h2 class="mb-3">@ViewData["Title"]</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="card p-3 shadow-sm">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <input asp-for="LessonId" type="hidden" />

    <div class="mb-3">
        <label asp-for="Question" class="form-label"></label>
        <textarea asp-for="Question" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Question" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="DifficultyLevel" class="form-label"></label>
            <input asp-for="DifficultyLevel" type="number" min="1" max="5" class="form-control" />
            <span asp-validation-for="DifficultyLevel" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="AudioFile" class="form-label">Audio File</label>
        <input asp-for="AudioFile" type="file" class="form-control" accept=".mp3,.wav,.ogg,.m4a,audio/*" />
        <span asp-validation-for="AudioFile" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.LessonId" class="btn btn-secondary">Cancel</a>
    </div>
    <hr />
    <h5 class="mb-3">Answer Options</h5>

    <div class="mb-3">
        <label asp-for="CorrectAnswer" class="form-label"></label>
        <input asp-for="CorrectAnswer" class="form-control" />
        <span asp-validation-for="CorrectAnswer" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FirstWrongAnswer" class="form-label"></label>
        <input asp-for="FirstWrongAnswer" class="form-control" />
        <span asp-validation-for="FirstWrongAnswer" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SecondWrongAnswer" class="form-label"></label>
        <input asp-for="SecondWrongAnswer" class="form-control" />
        <span asp-validation-for="SecondWrongAnswer" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ThirdWrongAnswer" class="form-label"></label>
        <input asp-for="ThirdWrongAnswer" class="form-control" />
        <span asp-validation-for="ThirdWrongAnswer" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.LessonId" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
