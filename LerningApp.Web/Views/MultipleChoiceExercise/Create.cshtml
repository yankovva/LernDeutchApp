@using LerningApp.Web.ViewModels.MultipleChoiceExercise
@model CreateMultipleChoiceExerciseViewModel

@{
    ViewData["Title"] = "Create Multiple Choice Exercise";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="text-muted">Създай multiple‑choice упражнение.</div>
    <a asp-controller="Lesson"
       asp-action="Details"
       asp-route-id="@Model.LessonId"
       class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input asp-for="LessonId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Question" class="form-label">Въпрос</label>
                        <input asp-for="Question" class="form-control" placeholder="Пример: Какво означава Haus?" />
                        <span asp-validation-for="Question" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CorrectAnswer" class="form-label">Правилен отговор</label>
                        <input asp-for="CorrectAnswer" class="form-control" placeholder="Пример: Къща" />
                        <span asp-validation-for="CorrectAnswer" class="text-danger"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstWrongAnswer" class="form-label">Грешен отговор 1</label>
                            <input asp-for="FirstWrongAnswer" class="form-control" placeholder="Пример: Куче" />
                            <span asp-validation-for="FirstWrongAnswer" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SecondWrongAnswer" class="form-label">Грешен отговор 2 (по желание)</label>
                            <input asp-for="SecondWrongAnswer" class="form-control" placeholder="Пример: Врата" />
                            <span asp-validation-for="SecondWrongAnswer" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="ThirdWrongAnswer" class="form-label">Грешен отговор 3 (по желание)</label>
                            <input asp-for="ThirdWrongAnswer" class="form-control" placeholder="Пример: Прозорец" />
                            <span asp-validation-for="ThirdWrongAnswer" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="DifficultyLevel" class="form-label">Трудност</label>
                            <select asp-for="DifficultyLevel" class="form-select">
                                <option value="1">Very Easy</option>
                                <option value="2">Easy</option>
                                <option value="3">Medium</option>
                                <option value="4">Hard</option>
                                <option value="5">Very Hard</option>
                            </select>
                            <span asp-validation-for="DifficultyLevel" class="text-danger"></span>
                        </div>
                        
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">💾 Създай</button>
                        <a asp-controller="Lesson"
                           asp-action="Details"
                           asp-route-id="@Model.LessonId"
                           class="btn btn-outline-secondary">Отказ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
