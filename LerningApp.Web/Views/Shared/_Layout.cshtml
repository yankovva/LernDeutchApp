@using LerningApp.Services.Data.Interfaces
@using LerningApp.Web.Infrastructure.Extensions
@inject ITeacherService teacherService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - LerningApp.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/LerningApp.Web.styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg navbar-light app-navbar">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                DeutchBuddy
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Course" asp-action="Index">Courses</a>
                    </li>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="UsersCourses" asp-action="Index">My Courses</a>
                        </li>
                        if (await teacherService.IsUserTeacherAsync(User.GetUserId()!))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Lesson" asp-action="Index">Lessons</a>
                            </li>
                        }
                    }
                   
                </ul>

                <div class="ms-auto">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="footer-mid">
    <div class="footer-mid-wrap">
        <div class="footer-mid-brand">
            <div class="brand-circle">L</div>
            <div>
                <div class="brand-name">LernEasy Deutsch</div>
                <div class="brand-sub">Онлайн учене на немски</div>
            </div>
        </div>

        <div class="footer-mid-links">
            <a asp-controller="Home" asp-action="About">
                <svg viewBox="0 0 24 24"><path d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Zm0-5 3 4h-6l3-4Z"/></svg>
                About
            </a>
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                if (await teacherService.IsUserTeacherAsync(User.GetUserId()!))
                {
                    <a asp-controller="Course" asp-action="Index">
                        <svg viewBox="0 0 24 24"><path d="M4 5h16v14H4zM6 7v10h12V7z"/></svg>
                        Курсове
                    </a>
                }
            }
            <a asp-controller="Lesson" asp-action="Index">
                <svg viewBox="0 0 24 24"><path d="M4 4h16v4H4zM4 10h10v4H4zM4 16h16v4H4z"/></svg>
                Уроци
            </a>
            <a asp-controller="Home" asp-action="Privacy">
                <svg viewBox="0 0 24 24"><path d="M12 2 4 5v6c0 5 3.5 9.7 8 11 4.5-1.3 8-6 8-11V5l-8-3Z"/></svg>
                Privacy
            </a>
        </div>

        <div class="footer-mid-copy">
            © @DateTime.Now.Year • DeutchBuddy 
        </div>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

<partial name="_NotificationsPartial" />

</body>
</html>
<style>
    .app-navbar {
        background: linear-gradient(90deg, #fff7ed 0%, #f0f9ff 100%);
        border-bottom: 1px solid #e5e7eb;
        box-shadow: 0 6px 20px rgba(15, 23, 42, 0.06);
        padding: 0.8rem 1rem;
    }

    .app-navbar .navbar-brand {
        font-size: 1.25rem;
        letter-spacing: 0.4px;
    }

    .app-navbar .nav-link {
        font-weight: 500;
        color: #111827;
        margin-right: 0.5rem;
    }

    .app-navbar .nav-link:hover {
        color: #2563eb;
    }

    .app-navbar .btn {
        border-radius: 999px;
        padding: 6px 14px;
    }

    .footer-mid {
        border-top: 1px solid #ff6800;
        background: #fff7ed;
        padding: 18px 16px;
    }

    .footer-mid-wrap {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 16px;
        align-items: center;
    }

    .footer-mid-brand {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .brand-circle {
        width: 40px;
        height: 40px;
        border-radius: 999px;
        background: #f97316;
        color: #fff;
        display: grid;
        place-items: center;
        font-weight: 800;
        box-shadow: 0 8px 16px rgba(234, 88, 12, 0.25);
    }

    .brand-name {
        font-weight: 800;
        color: #7c2d12;
        font-size: 1rem;
    }

    .brand-sub {
        color: #9a3412;
        font-size: 0.85rem;
    }

    .footer-mid-links {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .footer-mid-links a {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #9a3412;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.95rem;
    }

    .footer-mid-links a:hover {
        color: #ea580c;
    }

    .footer-mid-links svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
    }

    .footer-mid-copy {
        grid-column: 1 / -1;
        text-align: center;
        color: #9a3412;
        font-size: 0.85rem;
        margin-top: 6px;
    }
</style>
    